POSTGRES_DB=usage_dashboard
POSTGRES_USER=usage_dashboard
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://usage_dashboard:change-me@db:5432/usage_dashboard

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-generated-fernet-key
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=replace-with-random-admin-token

# Published image tag used by the default backend/frontend GHCR images.
IMAGE_TAG=main
# Override full image references if you publish under a different registry/name.
# BACKEND_IMAGE=ghcr.io/skulldorom/usage-dashboard-backend:main
# FRONTEND_IMAGE=ghcr.io/skulldorom/usage-dashboard-frontend:main

# External HTTP port for the fronting nginx service. Postgres stays internal-only.
NGINX_HTTP_PORT=3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SNAPSHOT_RETENTION_DAYS=90
VITE_API_BASE_URL=/api
